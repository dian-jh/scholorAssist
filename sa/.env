# ================================
# 系统核心配置
# ================================

# Mock数据开关 (true: 使用mock数据, false: 使用真实API)
# 修改此配置可在不重新编译的情况下切换数据源
VITE_USE_MOCK=false

# ================================
# 网关配置 (集中管理后端服务地址)
# ================================

# 网关协议 (http/https)
VITE_GATEWAY_PROTOCOL=http

# 网关主机地址
VITE_GATEWAY_HOST=localhost

# 网关端口 (修改此处即可切换到不同环境的网关)
VITE_GATEWAY_PORT=10100

# ================================
# API配置
# ================================

# API超时时间 (毫秒)
VITE_API_TIMEOUT=10000

# ================================
# 应用配置
# ================================

# 应用标题
VITE_APP_TITLE=文献辅助阅读系统

# 应用版本
VITE_APP_VERSION=1.0.0

# ================================
# 兼容性配置 (保持向后兼容)
# ================================

# 旧版API基础URL配置 (由配置系统自动生成，无需手动修改)
VITE_API_BASE_URL=http://localhost:10100/api

# 上传目录（用于Nginx映射），请按实际调整：
# Windows示例：D:/wwwroot/uploads 或 D:/project/uploads
UPLOADS_DIR=D:/wwwroot/uploads
# 旧版静态网关（已弃用，不再使用单独端口）
# VITE_UPLOADS_BASE_URL=